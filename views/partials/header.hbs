<header id="header">
  <div class="nav-top">
    <a href="/" class="logo">Quantum</a>
    <div class="search-box">
      <form action="#" method="get">
        <div class="inputs">
          <input type="submit" id="submit-search" value="">
          <input type="text" placeholder="Tìm kiếm sản phẩm" name="search-term">
        </div>
        <div class="select">
          <select name="category" id="category-to-search">
            <option value="" selected="selected">
              Danh mục >
            </option>
            {{# each categories }}
              <option value={{this.idcategory}}>{{this.categoryname}}</option>
            {{/each}}
          </select>
        </div>
      </form>
    </div>
    <div class="actions-items">
      <div class="action-item">
        <img src="/img/icons/ic_shopping_cart.png" alt="Sản phẩm trong giỏ">
        <a href="/cart"><span id="items-in-cart"></span>Sản phẩm</a>
      </div>
      <div class="action-item">
        <img src="/img/icons/ic_favorite_border.png" alt="Sản phẩm yêu thích">
        <a href="/wishlist">Yêu thích</a>
      </div>
      <div class="action-item">
        <img src="/img/icons/ic_account_circle.png" alt="Đăng nhập">
        {{# if user }}
          <div class="user-session">
            <p class="username">{{user.username}}</p>
            <a href="/log-out">Đăng xuất</a>
          </div>
        {{ else }}
          <a href="/sign-in">Đăng nhập</a>
        {{/if}}
      </div>
    </div>
  </div>
  <div class="line-div"></div>
  <div class="nav-bottom">
    <div class="all-categories dropdown">
      <div class="cta">
        <img src="/img/icons/ic_menu.png" alt="Dropdown all categories">
        Tất cả danh mục
      </div>
      <div class="submenu-dropdown">
        {{# each categories }}
          <a href="/filter/{{this.categoryname}}">{{this.categoryname}}</a>
        {{/each}}
      </div>
    </div>

    <div class="vertical-line"></div>

    <ul class="links">
      <li class="link"><a href="#">Ưu đãi sốc</a></li>
      <li class="link"><a href="#">Thương hiệu nổi bật</a></li>
      <li class="link"><a href="#">Bộ sưu tập</a></li>
      <li class="link"><a href="#">Bán chạy</a></li>
    </ul>
    <div class="config-site">
      <div class="vertical-line"></div>
      <div class="help-config config dropdown">
        <div class="cta">
          Trợ giúp
          <img src="/img/icons/ic_arrow_down.png">
        </div>
        <div class="submenu-dropdown">
          <a href="#">Diễn đàn</a>
          <a href="#">Hỏi đáp</a>
        </div>
      </div>
      <div class="vertical-line"></div>
      <div class="currency-config config dropdown">
        <div class="cta">
          USD
          <img src="/img/icons/ic_arrow_down.png">
        </div>
        <div class="submenu-dropdown">
          <a href="#">BRL</a>
          <a href="#">XBT</a>
        </div>
      </div>
      <div class="vertical-line"></div>
      <div class="language-config config dropdown">
        <div class="cta">
          Ngôn ngữ
          <img src="/img/icons/ic_arrow_down.png">
        </div>
        <div class="submenu-dropdown">
          <a href="#">Tiếng Bồ Đào Nha</a>
          <a href="#">Tiếng Anh</a>
        </div>
      </div>
    </div>
  </div>
</header>
