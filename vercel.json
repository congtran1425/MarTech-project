{
  "version": 2,
  "builds": [
    {
      "src": "api/index.js",
      "use": "@vercel/node",
      "config": {
        "includeFiles": [
          "node_modules/mysql/**",
          "node_modules/bcrypt-nodejs/**",
          "node_modules/bignumber.js/**",
          "routes/**",
          "dao/**",
          "helpers/**",
          "views/**",
          "public/**"
        ]
      }
    }
  ],
  "routes": [
    { "src": "/(.*)", "dest": "/api/index.js" }
  ]
}
